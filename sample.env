# Copyright @juktijol
# Channel t.me/juktijol

# Telegram API credentials (required)
API_ID=YOUR_API_ID
API_HASH=YOUR_API_HASH
BOT_TOKEN=YOUR_BOT_TOKEN

# Admin and owner ID
DEVELOPER_USER_ID=YOUR_USER_ID

# ── User Tracking ─────────────────────────────────────────────────────────
# LOG_GROUP_ID: ডাউনলোড করা ফাইল এই গ্রুপে log হবে।
# বটকে এই গ্রুপের Admin করতে হবে (message send permission)।
# Example: -1001234567890
LOG_GROUP_ID=YOUR_LOG_GROUP_ID

# Database URLs
# Only MONGO_URL is required. DATABASE_URL and DB_URL are optional (fallback to MONGO_URL).
MONGO_URL=YOUR_MONGO_URL
# DATABASE_URL=YOUR_DATABASE_URL
# DB_URL=YOUR_DB_URL

# Force Subscribe Channel (username without @)
# Users must join this channel to use the bot.
# Leave empty to disable force subscribe.
FORCE_SUB_CHANNEL=juktijol

# Command prefixes for bot commands
COMMAND_PREFIX=!|.|#|,|/
